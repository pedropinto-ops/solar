# ==========================================
# HOTEL PLATFORM — Environment Variables
# ==========================================
# Copie este arquivo para .env e ajuste os valores
# NUNCA commite o .env (já está no .gitignore)

# ------------------------------------------
# Database (Postgres)
# ------------------------------------------
DATABASE_URL="postgresql://hotel:hotel_dev_password@localhost:5432/hotel_platform?schema=public"

# ------------------------------------------
# Redis (cache, filas, sessões)
# ------------------------------------------
REDIS_URL="redis://localhost:6379"

# ------------------------------------------
# API (NestJS)
# ------------------------------------------
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# JWT — gere com: openssl rand -base64 64
JWT_SECRET="CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND_BASE64_64"
JWT_EXPIRES_IN=7d

# CORS — origens permitidas (separadas por vírgula)
CORS_ORIGINS="http://localhost:3000,http://localhost:3002"

# ------------------------------------------
# Asaas (pagamentos)
# ------------------------------------------
# Sandbox: https://sandbox.asaas.com
# Produção: https://api.asaas.com
ASAAS_API_URL="https://sandbox.asaas.com/api/v3"
ASAAS_API_KEY=""
ASAAS_WEBHOOK_TOKEN=""

# ------------------------------------------
# Focus NFe (notas fiscais)
# ------------------------------------------
# Sandbox: https://homologacao.focusnfe.com.br
# Produção: https://api.focusnfe.com.br
FOCUS_NFE_API_URL="https://homologacao.focusnfe.com.br"
FOCUS_NFE_TOKEN=""

# ------------------------------------------
# E-mail (Resend) — usado para e-mails transacionais (confirmação de reserva)
# ------------------------------------------
# Sem RESEND_API_KEY o envio fica DESLIGADO (apenas log) — não quebra nada.
# 1) Crie conta em https://resend.com e verifique o domínio (registros DNS).
# 2) Cole a API key aqui e o remetente do domínio verificado.
RESEND_API_KEY=""
EMAIL_FROM="Solar Irará Hotel <reservas@solar.gpcbahia.com.br>"

# ------------------------------------------
# Assistente de reserva por IA (Anthropic / Claude)
# ------------------------------------------
# Sem ANTHROPIC_API_KEY o assistente fica DESLIGADO (responde "indisponível").
# Obtenha em https://console.anthropic.com/ → API Keys. Custo por mensagem.
ANTHROPIC_API_KEY=""

# ------------------------------------------
# WhatsApp (Meta Cloud API) — Fase 2 (transporte do assistente)
# ------------------------------------------
# Sem PHONE_ID + ACCESS_TOKEN o webhook fica DESLIGADO (não envia nada).
# Webhook a configurar no painel da Meta:
#   URL:   https://<sua-api>/api/v1/public/whatsapp/webhook
#   Token: o mesmo valor de WHATSAPP_VERIFY_TOKEN (você inventa)
WHATSAPP_API_URL="https://graph.facebook.com/v20.0"
WHATSAPP_PHONE_ID=""          # Phone Number ID (não é o número; vem do painel Meta)
WHATSAPP_ACCESS_TOKEN=""      # token de acesso do app (permanente/system user)
WHATSAPP_VERIFY_TOKEN=""      # senha que você escolhe p/ o handshake de verificação
WHATSAPP_APP_SECRET=""        # App Secret (Meta) — valida a assinatura dos webhooks. NÃO deixar vazio em produção.
WHATSAPP_PROPERTY_SLUG="solar-irara"  # qual propriedade este número atende

# ------------------------------------------
# Storage (Cloudflare R2)
# ------------------------------------------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="hotel-platform-dev"
R2_PUBLIC_URL=""

# ------------------------------------------
# Frontend (Next.js)
# ------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
NEXT_PUBLIC_APP_NAME="Hotel Platform"

# ------------------------------------------
# Observability (opcional)
# ------------------------------------------
# SENTRY_DSN=""
# POSTHOG_API_KEY=""
