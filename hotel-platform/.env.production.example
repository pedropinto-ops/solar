# ============================================================
#  HOTEL PLATFORM — Variáveis de ambiente de produção
# ============================================================
#
#  ESTE ARQUIVO É UM TEMPLATE. NÃO use-o como .env real.
#  Os valores devem ser configurados nos painéis de:
#    - Railway (backend / api)  → variáveis com prefixo [API]
#    - Vercel  (frontend / web) → variáveis com prefixo [WEB]
#
#  Onde obter cada valor: ver comentários abaixo.
#
# ============================================================


# ============================================================
#  [API] Backend — configure no painel do Railway
# ============================================================

# --- Postgres (Neon) ---
# Obtenha em: https://console.neon.tech/ → seu projeto → Dashboard → Connection string
# IMPORTANTE: use a opção "Pooled connection" (com ?sslmode=require)
DATABASE_URL="postgresql://user:pass@ep-xxx-xxx-pooler.us-east-2.aws.neon.tech/dbname?sslmode=require"

# --- Redis (Upstash) ---
# Obtenha em: https://console.upstash.com/ → seu DB → "Connect to your database" → Node.js
REDIS_URL="rediss://default:xxx@xxx-xxxx.upstash.io:6379"

# --- JWT ---
# Gere uma string aleatória de pelo menos 32 caracteres.
# Use: https://generate-secret.vercel.app/64
JWT_SECRET="cole-aqui-um-secret-aleatorio-de-64-chars-muito-longo-e-imprevisivel"
JWT_EXPIRES_IN="7d"

# --- CORS ---
# URL do frontend Vercel — sem barra no final.
# Coloque TODAS as URLs separadas por vírgula (ex: domínio Vercel + domínio próprio).
CORS_ORIGINS="https://pousadavistamar.vercel.app,https://app.suapousada.com.br"

# --- Asaas (sandbox no início; produção depois) ---
# Sandbox: https://sandbox.asaas.com → Minha Conta → Integrações → Gerar API key
# Produção: https://www.asaas.com → mesma rota (só depois de validar tudo!)
ASAAS_API_KEY="$aact_YTU5YTE0M2M2N2I4MTliNzk0YTI5N2U5MzdjNWZmNDQ2NjgwYzZkMjMzNzlhNjJhMDJlMzcyMjQ3..."
ASAAS_API_URL="https://sandbox.asaas.com/api/v3"   # PROD: "https://www.asaas.com/api/v3"
ASAAS_WEBHOOK_TOKEN="defina-um-token-aleatorio-e-cole-tambem-no-painel-asaas-em-webhooks"

# --- Focus NFe (NFS-e) ---
# Sandbox: https://focusnfe.com.br → Painel → Tokens
# Deixe vazio por enquanto se ainda não for emitir nota fiscal.
FOCUSNFE_API_TOKEN=""
FOCUSNFE_API_URL="https://homologacao.focusnfe.com.br"   # PROD: "https://api.focusnfe.com.br"

# --- E-mail (Resend) ---
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Solar Irará Hotel <reservas@solar.gpcbahia.com.br>"

# --- Node ---
NODE_ENV="production"
# PORT é definida automaticamente pelo Railway, não precisa configurar
# API_HOST padrão "0.0.0.0" já funciona


# ============================================================
#  [WEB] Frontend — configure no painel do Vercel
# ============================================================

# URL pública do backend (Railway) — onde o Next.js faz fetch
# Pegue depois que o Railway estiver no ar: https://seu-app.up.railway.app
NEXT_PUBLIC_API_URL="https://hotel-api-production-xxxx.up.railway.app"

# (Opcional) Variável que aparece como ambiente — útil pra mostrar banner em staging
NEXT_PUBLIC_ENV="production"
